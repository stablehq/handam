# === 프로덕션 환경변수 ===
# 이 파일을 .env.production으로 복사한 후 값을 채워주세요.

DEMO_MODE=false

# Supabase PostgreSQL (connection pooler 6543 포트 사용)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# JWT (openssl rand -hex 32 로 생성)
JWT_SECRET_KEY=

# CORS (쉼표로 구분, 예: https://handam.example.com,http://localhost:5173)
CORS_ORIGINS=https://your-domain.com

# Admin 기본 비밀번호 (첫 배포 시 admin 계정 생성용, 이후 변경 권장)
ADMIN_DEFAULT_PASSWORD=

# SMS API
SMS_API_KEY=
SMS_API_SECRET=

# Claude API (LLM 자동응답, 미구현 시 비워두기)
CLAUDE_API_KEY=

# Naver Reservation
NAVER_BUSINESS_ID=
NAVER_COOKIE=

# Redis (사용하지 않으면 비워두기, Upstash 사용 시: redis://default:token@xxx.upstash.io:6379)
REDIS_URL=

# ChromaDB (RAG 미사용 시 비워두기)
CHROMADB_URL=
